# config.seed — Level 3 preinstall list for GL-MT3600BE
#
# This file is *appended* to .config by build.sh after `make defconfig`.
# Each line must be a standard kconfig declaration:
#   CONFIG_PACKAGE_xxx=y      - include xxx as a built-in (baked into firmware)
#   CONFIG_PACKAGE_xxx=m      - include xxx as a module (available via opkg)
#   # CONFIG_PACKAGE_xxx is not set - explicitly exclude
#
# Lines starting with # (except '# CONFIG_...') are comments.
#
# To disable any item, either delete the line or change =y to =n and re-run
# './build.sh --clean && ./build.sh'.
#
# Note: 5 baseline packages are already pulled in by the device profile
# (mt7987-2p5g-phy-firmware, kmod-mt7990-firmware, kmod-hwmon-pwmfan,
# kmod-usb3, automount), so we don't repeat them here.

# ---------------------------------------------------------------
# WiFi 7 / 802.11be MLO — enables Multi-Link Operation in hostapd/wpad
# ---------------------------------------------------------------
CONFIG_DRIVER_11BE_SUPPORT=y

# ---------------------------------------------------------------
# LuCI core + Chinese translations + Argon theme
# ---------------------------------------------------------------
CONFIG_PACKAGE_luci=y
CONFIG_PACKAGE_luci-compat=y
CONFIG_PACKAGE_luci-lib-ipkg=y
CONFIG_PACKAGE_luci-lua-runtime=y
CONFIG_PACKAGE_luci-theme-argon=y
CONFIG_PACKAGE_luci-i18n-base-zh-cn=y
CONFIG_PACKAGE_luci-i18n-firewall-zh-cn=y
CONFIG_PACKAGE_luci-i18n-package-manager-zh-cn=y
CONFIG_PACKAGE_luci-app-attendedsysupgrade=y

# ---------------------------------------------------------------
# Level 2 & 3: AdGuardHome DNS-level ad blocker
# ---------------------------------------------------------------
CONFIG_PACKAGE_adguardhome=y
CONFIG_PACKAGE_luci-app-adguardhome=y
CONFIG_PACKAGE_luci-i18n-adguardhome-zh-cn=y

# ---------------------------------------------------------------
# Level 3: OpenClash VPN / proxy
# Runtime note: kernel binaries (Meta/Mihomo) are NOT bundled;
# download them after first boot via LuCI → OpenClash → Upgrade.
# ---------------------------------------------------------------
CONFIG_PACKAGE_luci-app-openclash=y
CONFIG_PACKAGE_luci-i18n-openclash-zh-cn=y

# ---------------------------------------------------------------
# USB mass storage + filesystems (for sharing drives over network)
# ---------------------------------------------------------------
CONFIG_PACKAGE_kmod-usb-storage=y
CONFIG_PACKAGE_kmod-usb-storage-uas=y
CONFIG_PACKAGE_kmod-usb-xhci-mtk=y
CONFIG_PACKAGE_block-mount=y
CONFIG_PACKAGE_kmod-fs-ext4=y
CONFIG_PACKAGE_kmod-fs-vfat=y
CONFIG_PACKAGE_kmod-nls-cp437=y
CONFIG_PACKAGE_kmod-nls-iso8859-1=y

# ---------------------------------------------------------------
# USB cellular tethering — lets any USB-tethered phone or 4G/5G
# modem act as WAN. Covers all the major protocols.
# ---------------------------------------------------------------
CONFIG_PACKAGE_kmod-usb-net=y
CONFIG_PACKAGE_kmod-usb-net-rndis=y
CONFIG_PACKAGE_kmod-usb-net-cdc-ether=y
CONFIG_PACKAGE_kmod-usb-net-cdc-ncm=y
CONFIG_PACKAGE_kmod-usb-net-cdc-mbim=y
CONFIG_PACKAGE_kmod-usb-net-qmi-wwan=y
CONFIG_PACKAGE_kmod-usb-net-huawei-cdc-ncm=y
CONFIG_PACKAGE_kmod-usb-wdm=y
CONFIG_PACKAGE_kmod-usb-serial=y
CONFIG_PACKAGE_kmod-usb-serial-option=y
CONFIG_PACKAGE_kmod-usb-serial-wwan=y
CONFIG_PACKAGE_umbim=y
CONFIG_PACKAGE_uqmi=y
CONFIG_PACKAGE_comgt=y
CONFIG_PACKAGE_comgt-ncm=y
CONFIG_PACKAGE_usb-modeswitch=y

# ---------------------------------------------------------------
# Extras
# ---------------------------------------------------------------
# AmneziaWG — WireGuard fork with obfuscation
CONFIG_PACKAGE_kmod-amneziawg=y
CONFIG_PACKAGE_amneziawg-tools=y
CONFIG_PACKAGE_luci-proto-amneziawg=y
# nftables JSON output — useful for scripts that parse firewall rules
CONFIG_PACKAGE_nftables-json=y
# Keep opkg alongside ImmortalWrt's default apk for compatibility
# with packages that still assume opkg metadata.
# mwan4 multi-WAN health tracking & failover
CONFIG_PACKAGE_mwan4=y

# ---------------------------------------------------------------
# ModemManager — advanced mobile broadband modem management
# (DW5821e / T77W968 / other QMI/MBIM modems)
# ---------------------------------------------------------------
CONFIG_PACKAGE_modemmanager=y
CONFIG_PACKAGE_modemmanager-rpcd=y
CONFIG_PACKAGE_luci-proto-modemmanager=y

# ---------------------------------------------------------------
# Tailscale — mesh VPN with built-in NAT traversal
# ---------------------------------------------------------------
CONFIG_PACKAGE_tailscale=y
CONFIG_PACKAGE_luci-app-tailscale-community=y

# Enable 802.11be (WiFi 7) + MLO AP support in hostapd/wpad
# mt76 driver already has MLO compiled in unconditionally (no CONFIG_MT76_MLO)
CONFIG_DRIVER_11BE_SUPPORT=y

CONFIG_PACKAGE_opkg=y
# Terminal tools
CONFIG_PACKAGE_htop=y
CONFIG_PACKAGE_nano=y
CONFIG_PACKAGE_luci-app-ttyd=y
